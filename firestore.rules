rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: appointments
    // Document ID: auto-generated
    // Fields:
    //   - customerName: string (required, length 2-100)
    //   - customerPhone: string (required, length 8-20)
    //   - serviceId: string (required, in ['simples', 'esmaltação', 'alongamento', 'gel'])
    //   - serviceName: string (required)
    //   - price: number (required, positive)
    //   - date: string (required, YYYY-MM-DD format)
    //   - time: string (required, HH:MM format)
    //   - status: string (required, in ['pending', 'confirmed', 'cancelled'])
    //   - createdAt: timestamp (required)
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (request.auth.token.email == 'gustavomedeirosg12@gmail.com' || request.auth.token.email == 'arielly1997batista@icloud.com' || request.auth.token.email == 'ariellylorrana18@gmail.com');
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }
    
    function isValidDateString(dateStr) {
      return dateStr is string &&
        dateStr.matches("^\\d{4}-\\d{2}-\\d{2}$");
    }
    
    function isValidTimeString(timeStr) {
      return timeStr is string &&
        timeStr.matches("^\\d{2}:\\d{2}$");
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidAppointment(data) {
      let allowedFields = ['customerName', 'customerPhone', 'serviceId', 'serviceName', 'price', 'date', 'time', 'status', 'createdAt', 'professionalId', 'professionalName'];
      let validStatuses = ['pending', 'confirmed', 'cancelled'];
      
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(['customerName', 'customerPhone', 'serviceId', 'serviceName', 'price', 'date', 'time', 'status', 'createdAt']) &&
             validStringLength('customerName', 2, 100) &&
             validStringLength('customerPhone', 8, 20) &&
             validStringLength('serviceId', 1, 500) &&
             validStringLength('serviceName', 2, 500) &&
             (!('professionalId' in data) || validStringLength('professionalId', 1, 100)) &&
             (!('professionalName' in data) || validStringLength('professionalName', 2, 100)) &&
             data.price is number && data.price >= 0 &&
             isValidDateString(data.date) &&
             isValidTimeString(data.time) &&
             data.status in validStatuses &&
             data.createdAt is timestamp;
    }

    function isValidService(data) {
      let allowedFields = ['name', 'description', 'price', 'duration', 'isTraditional'];
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(['name', 'description', 'price', 'duration']) &&
             validStringLength('name', 2, 100) &&
             validStringLength('description', 0, 500) &&
             data.price is number && data.price >= 0 &&
             data.duration is number && data.duration > 0 &&
             (!('isTraditional' in data) || data.isTraditional is bool);
    }

    function isValidSettings(data) {
      let allowedFields = ['openTime', 'closeTime', 'slotInterval', 'closedDays', 'blockedDates', 'minAdvanceHours'];
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(['openTime', 'closeTime', 'slotInterval']) &&
             isValidTimeString(data.openTime) &&
             isValidTimeString(data.closeTime) &&
             data.slotInterval is number && data.slotInterval > 0 &&
             (!('closedDays' in data) || data.closedDays is list) &&
             (!('blockedDates' in data) || data.blockedDates is list) &&
             (!('minAdvanceHours' in data) || data.minAdvanceHours is number);
    }

    function isValidProfessional(data) {
      let allowedFields = ['name', 'role', 'active'];
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(allowedFields) &&
             validStringLength('name', 2, 100) &&
             validStringLength('role', 2, 100) &&
             data.active is bool;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /appointments/{appointmentId} {
      // Allow public to read appointments to check availability (time slots)
      allow read: if true;
      
      // Anyone can create an appointment (public booking form)
      allow create: if isValidAppointment(request.resource.data) && 
                    (request.resource.data.status == 'pending' || isAdmin());
      
      // Only authenticated users (the manicurist) can update or delete appointments
      allow update, delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidService(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidSettings(request.resource.data);
      allow delete: if isAdmin();
    }

    match /professionals/{professionalId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProfessional(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
